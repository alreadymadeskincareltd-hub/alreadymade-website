/* backup of src/index.css created by assistant */
/* stylelint-disable at-rule-no-unknown */
/* tailwind directives — processed by PostCSS/tailwindcss */
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap');
@tailwind base;
@tailwind components;
@tailwind utilities;
/* stylelint-enable at-rule-no-unknown */
@layer base {
 :root {
   --background: 72 14% 95%;
   --foreground: 0 0% 16%;
   --card: 0 0% 100%;
   --card-foreground: 0 0% 16%;
   --popover: 0 0% 100%;
   --popover-foreground: 0 0% 16%;
   --primary: 96 14% 52%;
   --primary-foreground: 0 0% 100%;
   --secondary: 40 8% 89%;
   --secondary-foreground: 0 0% 16%;
   --muted: 40 8% 89%;
   --muted-foreground: 0 0% 43%;
   --accent: 96 14% 52%;
   --accent-foreground: 0 0% 100%;
   --destructive: 0 84.2% 60.2%;
   --destructive-foreground: 0 0% 98%;
   --border: 40 8% 85%;
   --input: 40 8% 85%;
   --ring: 96 14% 52%;
   --radius: 0.625rem;
 }
}
@layer base {
 * {
   @apply border-border;
 }
 html {
   scroll-behavior: auto;
 }
 body {
   @apply bg-background text-foreground antialiased;
   font-family: 'Inter', sans-serif;
   overflow-x: hidden;
 }
}
/* Typography */
.font-heading {
 font-family: 'Cormorant Garamond', serif;
}
.font-mono {
 font-family: 'IBM Plex Mono', monospace;
}
.font-body {
 font-family: 'Inter', sans-serif;
}
/* Grain overlay */
.grain-overlay {
 position: fixed;
 top: 0;
 left: 0;
 width: 100%;
 height: 100%;
 pointer-events: none;
 z-index: 9999;
 opacity: 0.04;
 mix-blend-mode: multiply;
 background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
}
/* Vignette effect */
.vignette {
 position: absolute;
 inset: 0;
 pointer-events: none;
 background: radial-gradient(ellipse at center, transparent 0%, transparent 50%, rgba(0,0,0,0.15) 100%);
}
/* Section base styles */
.section-pinned {
 position: relative;
 width: 100vw;
 height: 100vh;
 overflow: hidden;
}
.section-flowing {
 position: relative;
 width: 100%;
 min-height: 100vh;
}
/* Card styles */
.card-white {
 background: white;
 border-radius: 10px;
 box-shadow: 0 18px 50px rgba(0,0,0,0.10);
}
/* Button styles */
.btn-primary {
 @apply bg-[#7B8F71] text-white px-8 py-3 rounded-md font-medium transition-all duration-300;
}
.btn-primary:hover {
 @apply bg-[#6a7d61] transform -translate-y-0.5;
}
.btn-secondary {
 @apply border border-[#2A2A2A] text-[#2A2A2A] px-8 py-3 rounded-md font-medium transition-all duration-300 bg-transparent;
}
.btn-secondary:hover {
 @apply bg-[#2A2A2A] text-white;
}
/* Label style */
.label-mono {
 @apply font-mono text-xs uppercase tracking-[0.18em] text-[#6E6E6E];
}
/* Smooth scroll container */
.smooth-scroll {
 scroll-behavior: smooth;
}
/* Hide scrollbar but keep functionality */
.hide-scrollbar {
 -ms-overflow-style: none;
 scrollbar-width: none;
}
.hide-scrollbar::-webkit-scrollbar {
 display: none;
}
/* Animation utilities */
.will-change-transform {
 will-change: transform;
}
/* Responsive text */
.text-responsive-h1 {
 font-size: clamp(44px, 5vw, 72px);
 line-height: 0.95;
 letter-spacing: -0.01em;
}
.text-responsive-h2 {
 font-size: clamp(34px, 3.6vw, 52px);
 line-height: 1.0;
}
